#!/usr/bin/with-contenv bashio

APP_KEY=$(bashio::config 'app_key')
VERSION_ID=$(bashio::config 'bible_version_id')
UPDATE_HOUR=$(bashio::config 'update_hour')

if bashio::var.is_empty "${APP_KEY}"; then
    bashio::log.fatal "App Key não configurada!"
    exit 1
fi

export APP_KEY
export VERSION_ID

bashio::log.info "Buscando versículo do dia..."
python3 /usr/bin/youversion_votd.py

while true; do
    sleep 60
    CURRENT_HOUR=$(date +%-H)
    CURRENT_MIN=$(date +%-M)
    if [ "${CURRENT_HOUR}" = "${UPDATE_HOUR}" ] && [ "${CURRENT_MIN}" = "1" ]; then
        bashio::log.info "Atualizando versículo do dia..."
        python3 /usr/bin/youversion_votd.py
    fi
done